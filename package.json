{
  "name": "lichess-tutor",
  "private": true,
  "license": "UNLICENSED",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "smoke:pwa": "playwright test",
    "a11y": "playwright test a11y",
    "preview": "vite preview",
    "test:worker": "vitest run --config backend/vitest.config.ts",
    "typecheck:worker": "tsc -p backend/tsconfig.json",
    "deploy:worker": "wrangler deploy -c backend/wrangler.toml",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "dexie": "4.4.3",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "10.6.0",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "sharp": "^0.35.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.2",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.9",
    "wrangler": "^4.106.0"
  }
}
