# O que o deploy do app NÃO precisa (o app servido é o Vite build -> dist/).
# Mantém src/, public/, index.html, vite/tsconfig, package.json. Exclui o resto
# para o contexto de deploy ficar leve e não subir artefatos de pesquisa.

# Artefatos de pesquisa / geração de imagens / prints (pesados, não-app)
output/
entrega/
screenshots/
LIVROS XADREZ PARA CONSULTA/
.superpowers/

# Testes e relatórios
test-results/
playwright-report/
coverage/

# Docs não fazem parte do bundle do app.
docs/
# ATENÇÃO: backend/ NÃO pode ser excluído aqui. O teste E2E src/infra/sync/syncE2E.test.ts importa
# backend/worker|fakeD1|types, e o `tsc -b` do build do Vercel type-checa os testes → sem backend/ o
# build quebra com TS2307 (Cannot find module). O worker continua sendo deployado à parte (wrangler).

# Logs locais
dev-server*.log
preview-server*.log
